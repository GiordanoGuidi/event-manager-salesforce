<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Live_Event_Requires_Event_Date</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status__c , &quot;Live&quot;),
  ISBLANK(Event_Date__c)
)</errorConditionFormula>
    <errorDisplayField>Event_Date__c</errorDisplayField>
    <errorMessage>An event must have an Event Date before it can be set to Live.</errorMessage>
</ValidationRule>

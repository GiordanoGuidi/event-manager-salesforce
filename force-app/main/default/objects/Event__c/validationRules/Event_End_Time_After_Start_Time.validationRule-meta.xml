<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Event_End_Time_After_Start_Time</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Start_Time__c)),
  NOT(ISBLANK(End_Time__c)),
  End_Time__c &lt;= Start_Time__c
)</errorConditionFormula>
    <errorDisplayField>End_Time__c</errorDisplayField>
    <errorMessage>End Time must be later than Start Time.</errorMessage>
</ValidationRule>

<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Event_Max_Capacity_Must_Be_Positive</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
NOT(ISBLANK(Max_Capacity__c)),
Max_Capacity__c &lt;= 0
)</errorConditionFormula>
    <errorDisplayField>Max_Capacity__c</errorDisplayField>
    <errorMessage>Max Capacity must be greater than zero.</errorMessage>
</ValidationRule>
